name = "doare-coffee-api"
main = "src/index.js"
compatibility_date = "2026-06-01"

[[d1_databases]]
binding = "DB"
database_name = "doare-coffee"
database_id = "REPLACE_WITH_D1_DATABASE_ID"

[vars]
ALLOWED_ORIGINS = "http://localhost:8080,https://doare-coffee.pages.dev,https://doraecoffee.io.vn,https://www.doraecoffee.io.vn"
FREE_SHIPPING_THRESHOLD = "500000"
SHIPPING_FEE = "30000"
BANK_ID = "MB"
BANK_ACCOUNT_NO = "REPLACE_WITH_BANK_ACCOUNT"
BANK_ACCOUNT_NAME = "DOARE COFFEE"
CONTACT_EMAIL = "huyntttb01626@gmail.com"
CONTACT_FROM_EMAIL = "contact@doraecoffee.io.vn"
# Set ADMIN_API_KEY with `wrangler secret put ADMIN_API_KEY`; never store it here.
# After onboarding Email Sending, add an EMAIL send_email binding.
